# Strata environment
# The core sample runs fully in mock mode with no configuration.
# To read from a deployed GenLayer contract, set all three values below.

# "mock" (default) or "contract"
NEXT_PUBLIC_STRATA_MODE=mock

# Deployed StrataContract address (only used when mode is "contract")
NEXT_PUBLIC_STRATA_CONTRACT=

# Network: studionet (default) | bradbury | localnet
NEXT_PUBLIC_STRATA_NETWORK=studionet
